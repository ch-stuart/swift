<!DOCTYPE html>
<%# paulirish.com/2008/conditional-stylesheets-vs-css-hacks-answer-neither/ -%>
<!--[if lt IE 7 ]> <html class="no-js ie6"> <![endif]-->
<!--[if IE 7 ]>    <html class="no-js ie7"> <![endif]-->
<!--[if IE 8 ]>    <html class="no-js ie8"> <![endif]-->
<!--[if (gte IE 9)|!(IE)]><!--> <html class="no-js"> <!--<![endif]-->
<head>
  <meta charset="utf-8">
  <%# Always force latest IE rendering engine (even in intranet) & Chrome Frame
       Remove this if you use the .htaccess -%>
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <title>
    <%= @title %><%= ": #{@subtitle}" if @subtitle.present? %> | handmade bicycle panniers and accessories
  </title>
  <meta description="<%= Company.first.description if Company.first.description.present? %>">
  <link type="text/plain" rel="author" href="http://builtbyswift.com/humans.txt">
  <!--[if lt IE 9]>
  <script src="http://html5shim.googlecode.com/svn/trunk/html5.js"></script>
  <![endif]-->
  <%= stylesheet_link_tag "application" %>
  <%= yield :css -%>
  <%= csrf_meta_tag %>
</head>
<body id="page_<%= controller_name.downcase %>_<%= action_name.downcase %>">
  <% if @company.front_door_sign.present? %>
    <h2 class="front_door_sign">
      <%= @company.front_door_sign %>
    </h2>
  <% end %>
  <%= yield :flash %>
  <%= yield :pre_box %>
  <div id="box" class="container_24">
    <%= yield %>
  </div>
  <div class="container_24">
    <%= render :partial => 'shared/footer' %>
  </div>
  <%= javascript_include_tag "application" %>
  <%= yield :js %>
  <%= render :partial => 'shared/analytics' unless Rails.env == "development" %>
  <p id="no_js_notice" class="container_24">
      Portions of this site require javascript. You should turn it on!
  </p>
  <p id="humans" class="container_24">
    This site was built by <a href="http://enure.net/portfolio">Charles Stuart</a> and designed by <a href="http://tinylittlehammers.com/">Dylan Mcconnell</a>.
  </p>
</body>
</html>

