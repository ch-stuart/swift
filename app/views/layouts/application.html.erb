<!DOCTYPE html>
<%# paulirish.com/2008/conditional-stylesheets-vs-css-hacks-answer-neither/ -%>
<!--[if lt IE 7 ]> <html class="no-js ie6"> <![endif]-->
<!--[if IE 7 ]>    <html class="no-js ie7"> <![endif]-->
<!--[if IE 8 ]>    <html class="no-js ie8"> <![endif]-->
<!--[if (gte IE 9)|!(IE)]><!--> <html class="no-js"> <!--<![endif]-->
<head>
  <meta charset="utf-8">
  <%# Always force latest IE rendering engine (even in intranet) & Chrome Frame
       Remove this if you use the .htaccess -%>
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <title>
    <%= @title %><%= ": #{@subtitle}" unless @subtitle.nil? %> | handmade bicycle panniers and accessories
  </title>
  <meta description="<%= Company.first.description if Company.first.description.present? %>">
  <!--[if lt IE 9]>
  <script src="http://html5shim.googlecode.com/svn/trunk/html5.js"></script>
  <![endif]-->
  <%= include_stylesheets :common %>
  <%= yield :css -%>
  <%= csrf_meta_tag %>
</head>
<body class="<%= (@hub == true) ? 'hub' : 'pub' %>" id="page_<%= controller_name.downcase %>_<%= action_name.downcase %>">
  <%= yield :flash %>
  <header>
    <% if false %>
      <h1 id="page_title" class="logo">
        <%= @title %>
      </h1>
    <% end %>
  </header>
  <div id="box" class="container_24">
    <%= yield %>
  </div>
  <% unless @hub %>
    <div class="container_24">
      <%= render :partial => 'shared/footer' %>
    </div>
  <% end %>
  <%= include_javascripts :common %>
  <%= yield :js -%>
  <%= render :partial => 'shared/analytics' unless RAILS_ENV == "development" %>
  <p id="no_js_notice" class="container_24">
      Portions of this site require javascript. You should turn it on!
  </p>
</body>
</html>

