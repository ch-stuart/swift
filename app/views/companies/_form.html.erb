<%= form_for(@company) do |f| %>
  <% if @company.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@company.errors.count, "error") %> prohibited this company from being saved:</h2>

      <ul>
      <% @company.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %><br />
    <%= f.text_field :title %>
  </div>
  <div class="field">
    <%= f.label :email %><br />
    <%= f.text_field :email %>
  </div>
  <div class="field">
    <%= f.label :phone %><br />
    <%= f.text_field :phone %>
  </div>
  <div class="field">
    <%= f.label :address %><br />
    <%= f.text_area :address %>
  </div>
  <div class="field">
    <%= f.label :description %><br />
    <%= f.text_area :description %>
    <p class="hint">
        The text that google uses for the "summary" text for the site.
    </p>
  </div>
  <div class="field">
    <%= f.label :delivery_time %><br />
    <%= f.text_area :delivery_time %>
    <p class="hint">
        The "handmade takes time" text on the order page.
    </p>
  </div>
  <div class="field">
    <%= f.label :front_door_sign %><br />
    <%= f.text_area :front_door_sign %>
    <p class="hint">
      This text will appear at the top of every public page.
    </p>
  </div>
  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>
