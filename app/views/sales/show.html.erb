<p id="notice"><%= notice %></p>

<h2>
    Order Details
</h2>
<p>
  <b>
    Date
  </b>
  <%= @sale.updated_at %>
</p>
<p>
  <b>Customer URL:</b>
  <a href="/orders/<%= @sale.guid %>">
      /orders/<%= @sale.guid %>
  </a>
</p>

<p>
  <b>Email:</b>
  <a href="mailto:<%= @sale.email %>">
    <%= @sale.email %>
  </a>
</p>

<p>
  <b>Amount:</b>
  <%= @sale.amount %> (price in cents)
</p>

<p>
  <b>Description:</b>
  <pre><%= JSON.pretty_generate(JSON.parse(@sale.description)) %></pre>
</p>


<%= link_to 'Edit', edit_sale_path(@sale) %> |
<%= link_to 'Back', sales_path %>
