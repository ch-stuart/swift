<div class="grid">
    <div class="unit w-3-4">
        <div class="grid">
            <div class="unit w-4-4">
                <h2>
                    Your Order
                </h2>
            </div>
        </div>
        <div class="grid hide-on-mobiles no-print">
            <div class="shoppin-cart__header unit w-1-4">Product</div>
            <div class="shoppin-cart__header unit w-1-4">Parts</div>
            <div class="shoppin-cart__header unit w-1-4">Quantity</div>
            <div class="shoppin-cart__header unit w-1-4">Total Price</div>
        </div>
        <% @description["products"].each do |product| %>
            <div class="grid">
                <div class="unit w-1-4">
                    <strong>
                        <%= product["title"] %>
                    </strong>
                    <br>
                    <span class=demph>Base Price: <%= number_to_currency product["price"].to_i %></span>
                    <br>
                    <a href=/products/<%= product["id"] %> class="demph no-print">
                        View Product
                    </a>
                </div>
                <div class="unit w-1-4">
                    <% if product["parts"].present? %>
                        <ul class="shoppin-cart__part-list">
                            <% product["parts"].each do |part| %>
                                <li>
                                    <%= part["title"] %>
                                    <% if part["price"].present? %>
                                        (<%= number_to_currency part["price"].to_i %>)
                                    <% end %>
                                    <% if part["selectedColor"].present? %>
                                        <span class="demph">
                                            <br>Fabric: <%= part["selectedColor"]["title"] %>
                                            <% if part["selectedColor"]["price"].present? %>
                                                (<%= number_to_currency part["selectedColor"]["price"].to_i %>)
                                            <% end %>
                                        </span>
                                    <% end %>
                                </li>
                            <% end %>
                        </ul>
                    <% else %>
                        n/a
                    <% end %>
                </div>
                <div class="unit w-1-4">
                    Qty: <%= product["quantity"] %>
                </div>
                <div class="unit w-1-4">
                    <strong>
                        <%= number_to_currency product["totalPrice"].to_i %>
                    </strong>
                </div>
            </div>
        <% end %>
        <hr class="print-only">
        <% if @sale[:tax_amount].present? %>
          <div class="grid shoppin-cart__cart-price-row" style="border-bottom: 0">
              <div class="unit w-3-4 hide-on-mobiles"></div>
              <div class="unit w-1-4">
                  Tax: <%= number_to_currency(cents_to_dollars(@sale[:tax_amount])) %>
              </div>
          </div>
        <% end %>
        <% if @sale[:shipping_charge].present? %>
          <div class="grid shoppin-cart__cart-price-row" style="border-bottom: 0">
              <div class="unit w-3-4 hide-on-mobiles"></div>
              <div class="unit w-1-4">
                  Shipping Charge: <%= number_to_currency(cents_to_dollars(@sale[:shipping_charge])) %>
              </div>
          </div>
        <% end %>
        <div class="grid shoppin-cart__cart-price-row">
            <div class="unit w-3-4 hide-on-mobiles"></div>
            <div class="unit w-1-4">
                Total: <strong><%= number_to_currency(cents_to_dollars(@sale[:total])) %></strong>
            </div>
        </div>
        <hr class="print-only">
        <div class="grid">
            <div class="unit w-1-2">
                <h4>
                    Email Address
                </h4>
                <p>
                    <%= @sale[:email] %>
                </p>
                <h4>
                    Order Date
                </h4>
                <p id="order_date">
                    <%= @sale[:created_at] %>
                </p>
                <h4>
                    Order ID
                </h4>
                <p>
                    <%= @sale[:guid] %>
                </p>
            </div>
            <div class="unit w-1-2">
                <% if @sale[:pickup] %>
                  <h4>
                      Shipment Tracking
                  </h4>
                  <p>
                    You will be picking up your order. We'll let you know by email when it's ready.
                  </p>
                <% else %>
                  <h4>
                      Shipment Tracking
                  </h4>
                  <p>
                      We will email you when your order has shipped.
                  </p>
                  <p>
                      The shipping information will also appear on this page.
                  </p>
                  <h4>
                      Shipment Address
                  </h4>
                  <p>
                      <%= @sale[:line1] %><br>
                      <%= @sale[:city] %>, <%= @sale[:state] %> <%= @sale[:zip_code] %>
                  </p>
                  <h4>
                      Shipment Charge
                  </h4>
                  <p>
                      <%= number_to_currency(cents_to_dollars(@sale[:shipping_charge])) %> via <%= @sale[:shipping_provider] %> <%= @sale[:shipping_service] %>.
                  </p>
                <% end %>
            </div>
        </div>
    </div>
    <div class="unit w-1-4 no-print">
        <h4>
            Questions?
        </h4>
        <p>
            If you have any questions about your order, contact us:
        </p>
        <ul class="nice-list">
            <li>
                <%= mail_to @company.email, @company.email, encode: "hex", body: "\n\n--\nSale ID: #{@sale.guid}" %>
            </li>
            <li>
                <%= link_to @company.phone, @company.phone_link %>
            </li>
        </ul>
        <h4>
            Delivery Time
        </h4>
        <div class="handmade_label">handmade</div>
        <p>
            <%= @company.delivery_time %>
        </p>
    </div>
</div>

<%= content_for :js do %>
    <script>
        (function() {
            localStorage.removeItem('cart');

            var orderDate = $('#order_date').text().trim()
            if (orderDate) {
                $('#order_date').text(strftime('%B %e, %Y', new Date(orderDate)))
            }
        })()
    </script>
<% end %>
