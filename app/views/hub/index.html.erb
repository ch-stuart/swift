<h1>
  Swift Industries Hub
</h1>

<h2>
  <%= link_to 'Products', products_path %>
</h2>
<ul>
  <% @products.each do |product| %>
    <li>
      <%= image_tag "#{product.kind}.png", :title => product.kind %>
      <%= image_tag "#{product.status}.png", :title => product.status %>
      <%= link_to product.title, product %>
      <%= link_to image_tag("edit.png"), edit_product_path(product), :class => 'icon_link fadesIn' %>
    </li>
  <% end %>
</ul>

<h2>
  <%= link_to 'Pages', pages_path %>
</h2>
<ul>
  <% @pages.each do |page| %>
    <li>
      <%= image_tag "#{page.status}.png" %>
      <%= link_to page.title, page %> <span class="private"><%= page.status if page.status == "Private" -%></span>
      <%= link_to image_tag("edit.png"), edit_page_path(page), :class => 'icon_link fadesIn' %>
    </li>
  <% end %>
</ul>

<h2>
  Company Info
</h2>
<ul>
  <li>
    <%= link_to @company.title, @company %>
  </li>
  <li>
    <%= link_to "Clear home page page cache.", hub_expire_home_path %><br>
    <span class="hint">Because of page caching (which makes the home page load as fast as possible), the home page content will not automatically update when the "Cycle Swift" blog has been updated.</span>
  </li>
</ul>

<h2>
  <%= link_to 'Colors', colors_path %>
</h2>
<ul>
  <% @colors.each do |color| %>
    <li>
      <span class="color_swatch" style="background-color: <%= color.hex -%>">
        &nbsp;&nbsp;&nbsp;&nbsp;
      </span>
      &nbsp;
      <%= link_to color.title, color %> <%= "$#{color.price}" unless color.price.blank? %>
      <%= link_to image_tag("edit.png"), edit_color_path(color), :class => 'icon_link fadesIn' %>
    </li>
  <% end %>
</ul>

<%= content_for :js do %>
    <script>
        $('.icon_link').hide();
        $('li').hover(function() {
            $('.icon_link').hide();
            $(this).find('.icon_link').fadeIn();
        }, function() {
            $(this).find('.icon_link').hide();
        });
    </script>
<% end %>
