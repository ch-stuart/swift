<ul class="nav-list">
  <% cache ["products_nav_categories", Category.all] do %>
    <% Category.all.each do |category| %>
      <li class="nav-list--item <%= set_column_classes(Category.all.length) %>">
        <% cache ["products_nav_category_title", category] do %>
          <strong class="nav-list--group-heading">
            <%= category.title %>
          </strong>
        <% end %>
        <% cache ["products_nav_category_products", category.products] do %>
          <ul class="nav-list--group">
            <% category.products.each do |product| %>
              <% cache ["products_nav_category_product", product] do %>
                <% next unless product.public? %>
                <li class="nav-list--group-item">
                  <%= link_to product.short_title, product, class: "nav-list--group-item-link" %>
                </li>
              <% end %>
            <% end %>
          </ul>
        <% end %>
      </li>
    <% end %>
  <% end %>
</ul>
