<h1>
  <%= @title %>
</h1>

<h2>
  products:
</h2>
<ul>
  <% @products.each do |product| %>
    <li>
      - <%= link_to product.title, product %>
    </li>
  <% end %>
</ul>

<h2>
  pages:
</h2>
<ul>
  <% @pages.each do |page| %>
    <li>
      - <%= link_to page.title, page %>
    </li>
  <% end %>
  <li>
    - <%= link_to "blog", APP_CONFIG['personal_blog_url'] %>
  </li>
</ul>

<h2>
  footer:
</h2>
<ul>
  <li>
    - <%= @company.phone %>
  </li>
  <li>
    - <%= @company.email %>
  </li>
</ul>