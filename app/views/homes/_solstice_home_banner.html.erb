    <%=
      image_set_tag "solstice/header-320.jpg",
      {
        'solstice/header-640.jpg' => "640w",
        'solstice/header-960.jpg' => "960w",
        'solstice/header-1280.jpg' => "1280w"
      },
      class: "S-banner-img js-srcset-img u-resp-img"
    %>
    <%= image_tag "solstice/hashtag-green-800.png", class: "S-banner-hashtag" %>
    <%= image_set_tag "solstice/logo-120.png", { 'solstice/logo-240.png' => '640w' }, class: "S-banner-logo js-srcset-img u-resp-img" %>
  </a>
</div>
