<%= content_for :css do %>
  <style>
  .container-logo {
    display: none;
  }
  .container-main {
    box-shadow: none;
    width: auto;
    margin: 0;
    border-top: none;
    border-right: none;
    border-left: none;
  }
  .container-footer {
    margin-top: 50px;
  }
  .container-w-padding {
    padding: 0;
  }
  </style>
  <link href='http://fonts.googleapis.com/css?family=Open+Sans:400,600' rel='stylesheet' type='text/css'>
<% end %>
<div ng-controller="SolsticeCtrl" class="S-ctrl">
  <div class="S-heading">
    <div class="grid">
      <div class="unit whole">
        <div class="S-logo"></div>
        <ul class="S-nav">
          <li class="S-nav__item">
            <a class="S-nav__link" href="#about" target="_self">
              About
            </a>
          </li>
          <li class="S-nav__item">
            <a class="S-nav__link" href="#signup" target="_self">
              Sign Up
            </a>
          </li>
          <li class="S-nav__item">
            <a class="S-nav__link" href="#map" target="_self">
              Map
            </a>
          </li>
          <li class="S-nav__item">
            <a class="S-nav__link" href="#social" target="_self">
              Social
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
  <div class="grid S-grid S-grid--intro" id="about">
    <div class="unit whole">
      <p class="S-p">
        Calling bicycle adventurers worldwide!
      </p>
      <p class="S-p">
        Swift Industries invites you to pack up and skip town for the Swift Campout, June 20th + 21st 2015.
      </p>
      <p class="S-p">
        Sign on to mark the map with your campout, then invite friends far and wide to band together for a night afield.
      </p>
      <p class="S-p">
        Wherever you may be, roll to camp and settle in for a night under starry skies. Go explore the Coast Range of California, hang a hammock in the Pine Barons, or wake to camp-coffee outside of Tokyo. Discover the solitude of an uncharted spot or head into the hills with a bunch of friends. Your call.
      </p>
      <p class="S-p">
        In the spirit of bike camping all we ask is that your adventure is self-supported and that you leave no trace.
      </p>
      <p class="S-p" id="signup" style="text-align: center">
        <br><br>
        <%= image_tag 'solstice/hashtag-green-800.png', alt: '#swiftcampout', class: 'S-hashtag-img' %>
      </p>
      <div class="Solistice-signup-btn-wrap">
        <a
          href="#"
          class="Solistice-signup-btn">
          Sign Up
        </a>
      </div>
      <p class="S-p S-p--disclaimer">
        Swift Industries is here to inspire your wandering ways, but we are in no way liable for safety or mishaps related to the Swift Campout. By creating a Swift Campout account you are taking full responsibility to travel safely and you are acknowledging the personal risks of traveling by bicycle.
      </p>
    </div>
    <div class="unit whole">
      <p class="S-p">
        Once you’ve joined there’s lots to win!
      </p>
      <p class="S-p">
        Share <a class="S-a" href="#">Campout Films</a> to earn a touring outfit from Swift Industries, complete with an Adventure Cycling Association membership and add <a class="S-a" href="#">Trip Journals</a> for to win Swift Campout accessories. But there’s more: we’ll kick-start give-aways with patches for the first 25 campers to sign up, and the goodies will keep coming as Swift Campout weekend rolls around.
      </p>
    </div>
  </div>
  <div class="grid S-grid S-grid--map" id="map">
    <div class="unit whole">
      <p class="S-p S-p--map-heading">
        Sign up to mark the map with your campout.
      </p>
      <leaflet
        center="kc"
        markers="markers"
        tiles="tiles"
        defaults="defaults">
      </leaflet>
      <div class="S-map--chooser">
        Map style:
        <button class="S-map--btn" ng-click="changeMap('stamenmap')">
          Stamen
        </button>
        or
        <button class="S-map--btn" ng-click="changeMap('openstreetmap')">
          OpenStreetMap
        </button>
      </div>
    </div>
  </div>
  <div class="grid S-grid S-grid--social" id="social">
    <div class="unit half">
      <sw-twitter tag="bicycle"></sw-twitter>
    </div>
    <div class="unit half">
      <sw-instagram tag="bicycle"></sw-instagram>
    </div>
  </div>
  <div class="grid S-grid S-grid--prizes" id="">
    <div class="unit half">
      <p class="S-p" style="font-weight:bold">
        Prizes
      </p>
      <p class="S-p">
        full touring set-up
        <br>patch
        <br>Swift t-shirts
        <br>Tenkara Rod Co Teton Rod
        <br>Adventure Cycling Association Membership
      </ul>
    </div>
    <div class="unit half">
      <p class="S-p" style="font-weight:bold">
        Recommended Gear
      </p>
      <p class="S-p">
        Junior Ranger Panniers
        <br>The Campout Kit: Kerchief , Patch, and Field Notes
        <br>Sno Peak Kitchen Kit
        <br>Zeitgeist Saddle Bag
        <br>Lark Travel Kite
      </p>
    </div>
  </div>
</div>

<%= render 'twitter' %>
<%= render 'instagram' %>

<%= content_for :js do %>
<script>

  var $win = $(window),
      $stickyNav = $('.S-nav'),
      stickyNavTop = $stickyNav.offset().top,
      $stickyLogo = $('.S-logo'),
      stickyLogoTop = $stickyLogo.offset().top,
      stickyLogoHeight = parseFloat($stickyLogo.css('height'));

  $(window)
    .scroll(function(e) {
      if (new Date() % 2 === 0 && !window.hasOwnProperty('ontouchstart')) {
        return;
      }

      setTimeout(function () {
        if ($win.scrollTop() > stickyNavTop) {
          if (!$stickyNav.hasClass('S-nav--fixed')) {
            $stickyNav.addClass('S-nav--fixed')
          }
        } else {
          if ($stickyNav.hasClass('S-nav--fixed')) {
            $stickyNav.removeClass('S-nav--fixed')
          }
        }


        if (!UA.isMobile() && $win.scrollTop() > stickyLogoTop + stickyLogoHeight) {
          if (!$stickyLogo.hasClass('S-logo--fixed')) {
            $stickyLogo.addClass('S-logo--fixed')
          }
        } else {
          if ($stickyLogo.hasClass('S-logo--fixed')) {
            $stickyLogo.removeClass('S-logo--fixed')
          }
        }
      }, 200);
    });

</script>
<% end %>
