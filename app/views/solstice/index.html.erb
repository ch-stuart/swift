<%= content_for :css do %>
  <style>
  .l-container--logo {
    display: none;
  }
  .l-container--fluid {
    box-shadow: none;
    width: auto;
    margin: 0;
    border-top: none;
    border-right: none;
    border-left: none;
  }
  .l-container--footer {
    margin-top: 50px;
  }
  .l-container--main {
    padding: 0;
  }
  .page_solstice_index .l-container--fluid {
    max-width: none;
  }
  </style>
  <link href='http://fonts.googleapis.com/css?family=Open+Sans:400,600' rel='stylesheet' type='text/css'>
<% end %>
<div ng-controller="SolsticeCtrl" class="S-ctrl">
  <div class="S-heading">
    <div class="row">
      <div class="col-xs-12">
        <div class="S-logo"></div>
        <ul class="S-nav">
          <li class="S-nav__item">
            <a class="S-nav__link" href="#about" target="_self">
              About
            </a>
          </li>
          <li class="S-nav__item">
            <a class="S-nav__link" href="#signup" target="_self">
              Sign Up
            </a>
          </li>
          <li class="S-nav__item">
            <a class="S-nav__link" href="#map" target="_self">
              Map
            </a>
          </li>
          <li class="S-nav__item">
            <a class="S-nav__link" href="#social" target="_self">
              Social
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
  <div class="S-Grid S-Grid--intro" id="about">
    <div class="row top-sm">
      <div class="col-xs-12 col-sm-4 around-sm">
        <%= render partial: 'intro_text' %>
      </div>
      <div class="col-xs-12 col-sm-4 first-sm around-sm">
        <%= render partial: 'prizes' %>
      </div>
      <div class="col-xs-12 col-sm-4 last-sm around-sm">
        <%= render partial: 'recommended_gear' %>
      </div>
    </div>
  </div>
  <div class="S-Grid S-Grid--post-intro">
    <div class="row">
      <div class="col-xs-12">
        <%= render partial: 'post_intro' %>
      </div>
    </div>
  </div>
  <div class="S-Grid S-Grid--map" id="map">
    <div class="row">
      <div class="col-xs-12">
        <%= render partial: 'map' %>
      </div>
    </div>
  </div>
  <div class="S-Grid S-Grid--social" id="social">
    <div class="row">
      <div class="col-xs-12 col-sm-6">
        <sw-twitter tag="bicycle"></sw-twitter>
      </div>
      <div class="col-xs-12 col-sm-6">
        <sw-instagram tag="bicycle"></sw-instagram>
      </div>
    </div>
  </div>
</div>

<%= render 'twitter' %>
<%= render 'instagram' %>
<%= render 'flickr' %>

<%= content_for :js do %>
<script>
  var $win = $(window),
      $stickyNav = $('.S-nav'),
      stickyNavTop = $stickyNav.offset().top,
      $stickyLogo = $('.S-logo'),
      stickyLogoTop = $stickyLogo.offset().top,
      stickyLogoHeight = parseFloat($stickyLogo.css('height'));

  $(window)
    .scroll(function(e) {
      if (new Date() % 2 === 0 && !window.hasOwnProperty('ontouchstart')) {
        return;
      }

      setTimeout(function () {
        if ($win.scrollTop() > stickyNavTop) {
          if (!$stickyNav.hasClass('S-nav--fixed')) {
            $stickyNav.addClass('S-nav--fixed')
          }
        } else {
          if ($stickyNav.hasClass('S-nav--fixed')) {
            $stickyNav.removeClass('S-nav--fixed')
          }
        }

        if (!UA.isMobile() && $win.scrollTop() > stickyLogoTop + stickyLogoHeight) {
          if (!$stickyLogo.hasClass('S-logo--fixed')) {
            $stickyLogo.addClass('S-logo--fixed')
          }
        } else {
          if ($stickyLogo.hasClass('S-logo--fixed')) {
            $stickyLogo.removeClass('S-logo--fixed')
          }
        }
      }, 200);
    });
</script>
<% end %>
