<footer class="row-footer">
    <div class="four columns">
        <h3 class="footer-heading">
            Our Products
        </h3>
        <ul class="footer-list">
            <% @products.each do |product| %>
                <li>
                    <%= link_to product.title, product, :class => "footer-link" %>
                </li>
            <% end %>
            <li>
                <%= link_to "Ready Made", store_path, :class => "footer-link" %>
            </li>
        </ul>
    </div>
    <div class="four columns">
        <h3 class="footer-heading">
            About Us
        </h3>
        <ul class="footer-list">
            <li>
                <%= link_to "Our Story", Page.find_by_path('our_story'), :class => "footer-link" %>
            </li>
            <li>
                <%= link_to "Cycle Swift Blog", APP_CONFIG['personal_blog_url'], :class => "footer-link" %>
            </li>
        </ul>
    </div>
    <div class="four columns">
        <h3 class="footer-heading">
            Shop
        </h3>
        <ul class="footer-list">
            <li>
                <%= link_to "Review Your Cart/Checkout", "#{APP_CONFIG['store_host']}#{APP_CONFIG['review_cart_path']}#{APP_CONFIG['store_userid']}", :class => "footer-link" %>
            </li>
        </ul>
    </div>
    <div class="four columns">
        <h3 class="footer-heading">
            Get in Touch
        </h3>
        <ul class="footer-list">
            <li>
                <%= mail_to @company.email, @company.email, :encode => "hex", :subject => "[via builtbyswift.com] ", :class => "footer-link" %>
            </li>
            <li>
                <%= link_to @company.phone, @company.phone_link, :class => "footer-link" %>
            </li>
            <li>
                <%= link_to "Follow us on Twitter", APP_CONFIG['twitter_url'], :class => "footer-link" %>
            </li>
            <li>
                <%= link_to "Like us on Facebook", APP_CONFIG['facebook_url'], :class => "footer-link" %>
            </li>
        </ul>
    </div>
    <%= image_tag "fox.gif", :id => "footer_fox" %>
</footer>
<br class="clear">
