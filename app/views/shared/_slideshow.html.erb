<% unless @photos.empty? %>
    <div id="swift_slideshow_wrapper">
        <div id="swift_slideshow">
            <% @photos.each_with_index do |(photo,key),idx| %>
                <%
                    if @photos[photo]['large_height'] == "500"
                        width = "265px"
                        height = "353px"
                    else
                        width = "470px"
                        height = "353px"
                    end
                %>
                <div id="photo<%= @photos[photo]['id'] -%>"
                     data-idx="<%= idx %>"
                     class="photo"
                     style="background-image: url(<%= @photos[photo]['large'] -%>);
                        background-size: <%= width -%> <%= height -%>;
                        -moz-background-size: <%= width -%> <%= height -%>;
                        -webkit-background-size: <%= width -%> <%= height -%>;"

                        data-text="<%= @photos[photo]['title'].empty? ? 'Untitled' : @photos[photo]['title'] %>"
                        data-caption="#photo_caption_<%= @photos[photo]['id'] -%>">
                </div>
                <div class="description" id="description<%= @photos[photo]['id'] -%>">
                    <h4>
                        <%= @photos[photo]['title'].empty? ? 'Untitled' : @photos[photo]['title'] -%>
                    </h4>
                    <div class="photo_description">
                        <%= raw @photos[photo]['description'] -%>
                    </div>
                    <p>
                        <a href="<%= @photos[photo]['flickr_url'] -%>">
                            view on Flickr ->
                        </a>
                    </p>
                    <div class="photo_nav">
                        <div class="goto next" data-goto="<%= (idx.to_i + 1) %>">
                            &#x2192;
                        </div>
                        <div class="goto previous" data-goto="<%= (idx.to_i - 1) %>">
                            &#x2190;
                        </div>
                    </div>
                </div>
            <% end -%>
            <div class="clear"></div>
            <nav>
                <% @photos.each_key do |photo| %>
                    <div class="grid_3 alpha omega">
                        <%= link_to "#{@photos[photo]['title'].empty? ? 'Untitled' : @photos[photo]['title']}",
                                    @photos[photo]['flickr_url'],
                                    'data-photo' => "#photo#{@photos[photo]['id']}",
                                    'data-description' => "#description#{@photos[photo]['id']}",
                                    :class => 'toggle eql_col' %>
                    </div>
                <% end %>
                <div class="clear"></div>
            </nav>
        </div>
    </div>
    <div class="clear"></div>
<% else %>
    <!-- No Photos -->
<% end %>

<%= content_for :js do %>
  <script>
    $.slideshow();
  </script>
<% end %>
