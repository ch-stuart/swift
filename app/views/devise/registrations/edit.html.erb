<div class="l-row l-row--session">
  <h2>
    Edit Profile
  </h2>

  <% resource.build_camper if resource.camper.nil? %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= devise_error_messages! %>

    <div class="label-input-pair">
      <%= f.label :contact, "Name", class: "label" %>
      <%= f.text_field :contact, autofocus: true, class: "input" %>
      <% if request.fullpath.include? "swiftcampout" %>
        <p class="label-input-pair__hint">
          Your name will not be shared publicly.
        </p>
      <% end %>
    </div>

    <div class="label-input-pair">
      <%= f.label :city, class: "label" %>
      <%= f.text_field :city, class: "input" %>
    </div>

    <div class="label-input-pair">
      <%= f.label :state, class: "label" %>
      <%= f.text_field :state, class: "input" %>
    </div>

    <div class="label-input-pair">
      <%= f.label :zip_code, class: "label" %>
      <%= f.text_field :zip_code, class: "input" %>
    </div>

    <div class="label-input-pair">
      <%= f.label :email, class: "label" %>
      <%= f.email_field :email, class: "input" %>
    </div>

    <%# render partial: 'camper_fields', locals: { f: f } %>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div>Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
    <% end %>

    <div class="label-input-pair">
      <%= f.label :password, class: "label" %>
      <%= f.password_field :password, autocomplete: "off", class: "input" %>
      <p class="label-input-pair__hint">
        Leave blank if you don't want to change it.
      </p>
    </div>
    <div class="label-input-pair">
      <%= f.label :password_confirmation, class: "label" %>
      <%= f.password_field :password_confirmation, autocomplete: "off", class: "input" %>
    </div>

    <div class="label-input-pair">
      <%= f.label :current_password, class: "label" %>
      <%= f.password_field :current_password, autocomplete: "off", class: "input" %>
      <p class="label-input-pair__hint">
        We need your current password to confirm your changes.
      </p>
    </div>

    <div class="submit-wrap">
      <%= f.submit "Update", class: "btn" %>
    </div>

  <% end %>

  <h4>
    Cancel my account
  </h4>
  <div class="submit-wrap">
    <%= button_to "Cancel my account", registration_path(resource_name), class: "btn", data: { confirm: "Are you sure?" }, method: :delete %>
  </div>

  <%= link_to "Back", :back %>
</div>
