<div class="l-row l-row--session">
  <h2>
    <% if request.fullpath.include? "swiftcampout" %>
      Swift Campout Sign Up
    <% elsif request.fullpath.include? "wholesale" %>
      Dealer Sign Up
    <% else %>
      Sign Up
    <% end %>
  </h2>
  <% if request.fullpath.include? "swiftcampout" %>
    <p>
      Blurb about signing up.
    </p>
  <% end %>
  <% if request.fullpath.include? "wholesale" %>
    <p>
      To become a Swift Industries dealer, you must apply by emailing
      <%= mail_to Company.first.email, Company.first.email, encode: "hex", subject: "Dealer Sign Up" %>.
    </p>
  <% end %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= devise_error_messages! %>
    <% if request.fullpath.include? "swiftcampout" %>
      <input type="hidden" name="user[is_attending_campout_in_2015]" value="true">

    <% end %>
    <% if request.fullpath.include? "wholesale" %>
      <input type="hidden" name="user[is_pending_wholesale]" value="true">
    <% end %>

    <div class="label-input-pair">
      <%= f.label :contact, "Name", class: "label" %>
      <%= f.text_field :contact, autofocus: true, class: "input" %>
      <% if request.fullpath.include? "swiftcampout" %>
        <p class="label-input-pair__hint">
          Your name will not be shared publicly.
        </p>
      <% end %>
    </div>

    <div class="label-input-pair">
      <%= f.label :city, class: "label" %>
      <%= f.text_field :city, class: "input" %>
    </div>

    <div class="label-input-pair">
      <%= f.label :state, class: "label" %>
      <%= f.text_field :state, class: "input" %>
    </div>

    <div class="label-input-pair">
      <%= f.label :zip_code, class: "label" %>
      <%= f.text_field :zip_code, class: "input" %>
    </div>

    <div class="label-input-pair">
      <%= f.label :email, class: "label" %>
      <%= f.email_field :email, class: "input" %>
      <p class="label-input-pair__hint">
        We will not share your email address.
      </p>
    </div>

    <div class="label-input-pair">
      <%= f.label :password, class: "label" %>
      <%= f.password_field :password, autocomplete: "off", class: "input" %>
      <p class="label-input-pair__hint">
        Password must be a minimum of 10 characters.
      </p>
    </div>

    <div class="label-input-pair">
      <%= f.label :password_confirmation, class: "label" %>
      <%= f.password_field :password_confirmation, autocomplete: "off", class: "input" %>
    </div>

    <% if request.fullpath.include? "swiftcampout" %>
      <div class="label-input-pair">
        <label for="agree" class="label">
          <input type="checkbox" id="agree">
          I agree that Swift Industries is not liable for any harm that may come to me from bears, mountain lions or any other source during this campout.
        </label>
      </div>
    <% end %>

    <div class="submit-wrap">
      <%= f.submit "Sign up", class: "btn", disabled: "disabled", id: "submitBtn" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>

<%= content_for :js do %>
  <script>
    (function handleAgree() {
      var submitBtn = document.getElementById('submitBtn'),
          agreeCheckbox = document.getElementById('agree');

      if (!submitBtn || !agreeCheckbox) {
        return;
      }

      document
        .getElementById('agree')
        .onchange = function(event) {
          if (this.checked) {
            submitBtn.removeAttribute('disabled');
          } else {
            submitBtn.setAttribute('disabled', 'disabled');
          }
        };
    })();
  </script>
<% end %>
