<%= form_for(@user) do |f| %>
  <% if @user.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>

      <ul>
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :email %>
    <p>
      <%= mail_to @user.email %>
    </p>
  </div>
  <div class="field">
    <%= f.label :admin %>
    <p>
      <em>Not editable</em>
    </p>
  </div>
  <div class="field">
    <%= f.label :wholesale, "Dealer" %>
    <%= f.check_box :wholesale %>
  </div>
  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>
