<form
    id="order_form"
    class="form-order"
    ng-submit="onFormSubmit()">

    <%= render 'order_form_sizes' %>
    <%= render 'order_form_question' %>
    <%= render 'order_form_parts' %>
    <h4 class="order-section-heading">
        Order it!
    </h4>
    <div class="row row-submit">
        <button type="submit" id="submit_order">
            Submit Order
        </button>
        <button type="submit" id="add_to_cart">
            Add to Cart and Buy More Stuff
        </button>
    </div>

</form>
