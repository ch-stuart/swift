<div
    ng-hide="part.price && !part.activated"
    class="color-picker--wrapper">

    <div
        ng-show="part.selectedColor"
        class="color-picker--swatch color-picker--swatch-selected"
        style="background-color: {{ part.selectedColor.hex }}; border: 1px solid {{ part.selectedColor.hex }}"
        title='{{ part.selectedColor.title }}  (${{ part.selectedColor.price }})'>
        <span ng-show="part.selectedColor.price">
            ${{ part.selectedColor.price }}
        </span>
    </div>

    <div class="color-picker--swatches" ng-show="part.showColors">
        <div
            ng-repeat="color in part.colors"
            ng-click="onColorSwatchClicked()"
            class="color-picker--swatch"
            style="background-color: {{ color.hex }}; border: 1px solid {{ color.hex }}"
            title='{{ color.title }}  (${{ color.price }})'>
            <span ng-show="color.price">
                ${{ color.price }}
            </span>
        </div>
    </div>

    <div
        class="color-picker--change button remove-bottom {{ part.inputIsInvalid }}"
        ng-click="onChooseColorButtonClicked()"
        ng-show="!part.showColors">
        Choose Color
    </div>

    <br class="clear">

</div>
