<%= form_for @product do |f| %>
  <% if @product.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@product.errors.count, "error") %> prohibited this product from being saved:</h2>

      <ul>
      <% @product.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %><br />
    <%= f.text_field :title %>
  </div>
  <div class="field">
    <%= f.label :description %><br />
    <%= f.text_area :description %>
  </div>
  <div class="field">
    <%= f.label :price %><br />
    <%= f.text_field :price %>
  </div>
  <div class="field">
    <%= f.label :flickr_tag %><br />
    <%= f.text_field :flickr_tag %>
  </div>
  <div class="field">
    <%= f.label :specs %><br />
    <%= f.text_area :specs %>
  </div>
  <div class="field">
    <%= f.label :status %><br />
    <%= f.select :status, options_for_select(["Private", "Public"], :selected => @product.status) %>
  </div>
  <div class="field">
    <p>Parts</p>
  </div>
  <%= f.fields_for :parts do |form| %>
    <%= render :partial => 'parts_fields', :locals => { :f => form } %>
  <% end %>
  <p>
    <%= link_to_add_fields "Add Part", f, :parts %>
  </p>
  
  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>
