<% if @product.parts.present? %>
    <h4 class="order-section-heading">
        Customize your parts
    </h4>
    <div class="row row-parts">
        <% @product.parts.each do |part| %>
            <div class="label-input-pair">
                <%# If it has a price, display a checkbox so they can add it. %>
                <label class="label"
                    <% if part.price.present? %>
                        for="checkbox_<%= digest(part.title +  part.id.to_s) %>"
                    <% end %>
                >
                    <% if part.price.present? %>
                        <input
                            id="checkbox_<%= digest(part.title +  part.id.to_s) %>"
                            type="checkbox"
                            class="input input-checkbox"
                            data-hash="<%= digest(part.title +  part.id.to_s) %>"
                            data-product="<%= part.title %>"
                            data-price="<%= part.price_for(session[:is_wholesale_user]) %>">
                    <% end %>
                    <%= part.title %>
                    <%= "$#{part.price_for(session[:is_wholesale_user])}" if part.price.present? %>
                </label>
                <% if part.colors.present? %>
					<div class="input input-color <%= 'input-color-with-optional-part' if part.price.present? && part.colors.present? %>">
                        <%= render "color_picker", :part => part, :colors => part.colors %>
                        <select
                            id="<%= digest('select' + part.title) %>"
                            name="product1[]"
                            class="select-color"
                            data-hash="<%= digest('select' + part.title) %>"
                            style="display:none">
                            <option value="invalid">
                                Choose One
                            </option>
                            <% part.colors.each do |color| %>
                                <option
                                    <% if color.price.present? %>
                                        data-hash="<%= digest(color.title + color.id.to_s) %>"
                                        data-color="<%= color.title %>"
                                        data-price="<%= color.price_for(session[:is_wholesale_user]) %>"
                                    <% end %>
                                    data-hex="<%= color.hex %>"
                                    <%# The value sets the title of the part which shows up at Mals %>
                                    value="<%= part.title %> (<%= color.title %><%= ": $#{color.price_for(session[:is_wholesale_user])}" unless color.price.blank? %>) ">
                                    <%= color.title %>
                                    <%= "($#{color.price_for(session[:is_wholesale_user])})" unless color.price.blank? %>
                                </option>
                            <% end %>
                        </select>
                    </div>
                <% end %>
            </div>
        <% end %>
    </div>
<% end %>
