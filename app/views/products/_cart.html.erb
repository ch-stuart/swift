<div class="shoppin-cart" ng-show="cart.showCart">
    <h3>
        Shoppin&rsquo; Cart
    </h3>
    <div class="row" ng-show="cart.products.length">
        <table class="shoppin-cart__table">
            <thead>
                <th>
                    Product
                </th>
                <th>
                    Parts
                </th>
                <th>
                    Price
                </th>
                <th></th>
            </thead>
            <tbody>
                <tr ng-repeat="savedProduct in cart.products">
                    <td>
                        {{ savedProduct.title }} ${{ savedProduct.price }}
                    </td>
                    <td>
                        <ul>
                            <li ng-repeat="part in savedProduct.parts">
                                <strong>Name:</strong> {{ part.title }}
                                <span ng-show="part.selectedColor">
                                    <br><strong>Fabric:</strong> {{ part.selectedColor.title }}
                                    <span ng-show="part.selectedColor.price">
                                        <br><strong>Fabric Price:</strong> ${{ part.selectedColor.price }}
                                    </span>
                                </span>
                                <span ng-show="part.price">
                                    <br><strong>Part Price:</strong> ${{ part.price }}
                                </span>
                            </li>
                        </ul>
                    </td>
                    <td>
                        ${{ savedProduct.totalPrice }}
                    </td>
                    <td>
                        <button ng-click="onRemoveFromCartButtonClicked(savedProduct.uniqueId)">
                            Remove
                        </button>
                    </td>
                </tr>
                <tr>
                    <td colspan="2">
                        <strong>Total Price:</strong>
                    </td>
                    <td>
                        ${{ cart.totalPrice }}
                    </td>
                    <td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="row shoppin-cart__toolbar" ng-show="cart.products.length">
        <button ng-click="onShopMoreButtonClicked()">
            Continue Shopping
        </button>
        <button ng-click="onCheckOutButtonClicked()">
            Check Out
        </button>
    </div>
    <div class="row remove-bottom shoppin-cart__fabric-charge-notice" ng-show="cart.products.length">
        <h5>
            A Note About Our Fabric Charges
        </h5>
        <ul class="shoppin-cart__fabric-charge-notice__ul nice-list">
            <li>For each product, you will only be charged for your most expensive fabric choice.</li>
            <li>The charge is only applied once per bag.</li>
            <li>Use it as many times as you&rsquo;d like!</li>
        </ul>
    </div>
    <div class="row shoppin-cart__empty" ng-hide="cart.products.length">
        <p>
            Nothing is in your cart.
        </p>
        <button ng-click="onShopMoreButtonClicked()">
            Continue Shopping
        </button>
    </div>
</div>
