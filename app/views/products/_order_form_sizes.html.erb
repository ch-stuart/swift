<div ng-show="product.sizes">
    <h4 class="order-section-heading">
        Sizing
    </h4>
    <div class="row row-sizes">
        <div class="label-input-pair">
            <label for="productpr1" class="label">
                Choose your size!
            </label>
            <select id="productpr1" name="productpr1" class="select-size">
                <option value="invalid">
                    Choose One
                </option>
                <option ng-repeat="size in product.sizes" value="{{ product.title }}, {{ size.title }}:{{ size.price }}">
                    {{ size.title }} (${{ size.price }})
                </option>
            </select>
        </div>
    </div>
</div>
