<h3>
    <%= title %>
</h3>
<table>
  <tr>
    <th>Type</th>
    <th>Status</th>
    <th></th>
    <th>Title</th>
    <th>Price</th>
    <th>Humane Price</th>
    <th>WS Price</th>
    <th>WS Humane Price</th>
    <th></th>
  </tr>
<% products.each do |product| %>
  <tr>
    <td><%= image_tag "#{product.kind}.png" %></td>
    <td><%= image_tag "#{product.status}.png" %></td>
    <td>
        <%= link_to image_tag("edit.png"), edit_product_path(product) %>
    </td>
    <td>
      <%= link_to product.title, product %>
    </td>
    <td><%= product.price %></td>
    <td><%= product.humane_price %></td>
    <td>
        <% if product.wholesale_price.present? %>
            <%= product.wholesale_price %>
        <% else %>
            <span style="color:red; font-size: 120%;">
              ✗
            </span>
        <% end %>
    </td>
    <td>
        <% if product.wholesale_humane_price.present? %>
            <%= product.wholesale_humane_price %>
        <% else %>
            <span style="color:red; font-size: 120%;">
              ✗
            </span>
        <% end %>
    </td>
    <td>
        <%= link_to image_tag("destroy.png"), product, :confirm => 'Are you sure you want to delete this product?', :method => :delete %>
    </td>
  </tr>
<% end %>
</table>
