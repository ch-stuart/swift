<% unless @product.public? %>
    <%# this notifies the administrator that the product is private. %>
    <p id="private_notice">
        private!
    </p>
<% end %>
<%= render :partial => 'shared/checkout' %>
<div class="grid_12 left_col">
    <div class="content_wrapper">
        <div class="content">
            <%= render :partial => 'shared/slideshow' %>
            <div class="text_content">
                <!-- TODO: put anything here? -->
                <%= render :partial => 'testimonials' %>
                <div class="clear"></div>
            </div>
        </div>
    </div>
</div>
<div class="grid_12 omega right_col">
    <div class="content_wrapper">
        <div class="content">
            <div class="text_content">
                <%# if the shop is closed, don't show the order form. %>
                <% if @company.close_shop? %>
                    <h2 class="woah">
                        <span><%= @company.close_shop_message %></span>
                    </h2>
                    <%= render 'order_marketing' %>
                <%# if the product is not for sale, don't show the order form. %>
                <% elsif @product.not_for_sale? %>
                    <h2 class="woah">
                        <span><%= @product.not_for_sale_message %></span>
                    </h2>
                    <%= render 'order_marketing' %>
                <%# else, show the order form. %>
                <% else %>
                    <form id="order_form" method="post" action="<%= APP_CONFIG['store_host'] %><%= APP_CONFIG['add_to_cart_path'] %>" data-count="1">
                        <%# -------- START MAL's fields -------- %>
                        <%# Mal's userid %>
                        <input type="hidden" name="userid" value="<%= APP_CONFIG['store_userid'] %>">
                        <%# Mal's needs different params sent if the product has diff. prices based on size. %>
                        <% unless @product.sizes.present? %>
                            <input type="hidden" name="product1[]" value="<%= @product.title %>">
                            <input type="hidden" name="price1" value="<%= @product.price %>">
                        <% end %>
                        <%# we only send 1 product, all the time. might need to be changed in the future. %>
                        <input type="hidden" name="qty1" value="1">
                        <%# Parts fields get put in here for processing by Mal's %>
                        <div id="parts"></div>
                        <%# -------- END MAL's fields -------- %>
                        <%# Show the marketing text for this product %>
                        <%= render 'order_marketing' %>
                        <% if @product.sizes.present? %>
                            <div class="fields">
                                <div class="field">
                                    <h3>
                                        Sizing
                                    </h3>
                                    <p class="label">
                                        Choose your size!
                                    </p>
                                    <p class="input">
                                        <select name="productpr1" class="size_select">
                                            <option data-hex="#444" value="invalid">
                                                Choose One
                                            </option>
                                            <% @product.sizes.each do |size| %>
                                                <option value="<%= @product.title %>, <%= size.title %>:<%= size.price %>">
                                                    <%= size.title %> ($<%= size.price %>)
                                                </option>
                                            <% end %>
                                        </select>
                                    </p>
                                    <div class="clear"></div>
                                </div>
                            </div>
                        <% end %>
                        <% unless @product.question.blank? %>
                            <div class="fields">
                                <div class="field">
                                    <p class="label">
                                        <%= @product.question %>
                                    </p>
                                    <p class="input">
                                        <% if @product.answer.blank? %>
                                            <input type="text" name="product1[]">
                                        <% else %>
                                            <select name="product1[]">
                                                <option value="invalid">
                                                    Choose One
                                                </option>
                                                <% @product.answer.split(',').each do |option| %>
                                                    <option>
                                                        <%= option %>
                                                    </option>
                                                <% end %>
                                            </select>
                                        <% end %>
                                    </p>
                                    <div class="clear"></div>
                                </div>
                            </div>
                        <% end %>
                        <% if @product.parts.present? %>
                            <h3>
                                Customize your parts
                            </h3>
                            <div class="fields">
                                <% @product.parts.each do |part| %>
                                    <div class="field">
                                        <p class="label">
                                            <%# If it has a price, display a checkbox so they can add it. %>
                                            <% if part.price.present? %>
                                                <input
                                                    id="checkbox_<%= digest(part.title +  part.id.to_s) %>"
                                                    type="checkbox"
                                                    class="part_checkbox"
                                                    data-hash="<%= digest(part.title +  part.id.to_s) %>"
                                                    data-product="<%= part.title %>"
                                                    data-price="<%= part.price %>">
                                            <% end %>
                                            <label for="checkbox_<%= digest(part.title +  part.id.to_s) %>">
                                                <%= part.title %>
                                                <%= "$#{part.price}" if part.price.present? %>
                                            </label>
                                        </p>
                                        <% unless part.colors.blank? %>
                                            <p class="input">
                                                <select
                                                    name="product1[]"
                                                    class="color_select"
                                                    data-hash="<%= digest('select' + part.title) %>">
                                                    <option data-hex="#444" value="invalid">
                                                        Choose One
                                                    </option>
                                                    <% part.colors.each do |color| %>
                                                        <option
                                                            <% if color.price.present? %>
                                                                data-hash="<%= digest(color.title + color.id.to_s) %>"
                                                                data-color="<%= color.title %>"
                                                                data-price="<%= color.price %>"
                                                            <% end %>
                                                            data-hex="<%= color.hex %>"
                                                            <%# The value sets the title of the part which shows up at Mals %>
                                                            value="<%= part.title %> (<%= color.title %><%= ": $#{color.price}" unless color.price.blank? %>) ">
                                                            <%= color.title %>
                                                            <%= "($#{color.price})" unless color.price.blank? %>
                                                        </option>
                                                    <% end %>
                                                </select>
                                            </p>
                                        <% else %>
                                            <p class="input no_color_choices">
                                                <i>No color choices.</i>
                                            </p>
                                        <% end %>
                                    </div>
                                    <div class="clear"></div>
                                    <div class="divider"></div>
                                <% end %>
                            </div>
                        <% end %>
                        <div class="fields">
                            <p class="label"></p>
                            <p class="input">
                                <button type="submit" id="submit_order">
                                    Submit Order
                                </button>
                            </p>
                            <div class="clear"></div>
                        </div>
                        <% if @product.is_product? %>
                            <div class="fields handmade">
                                <p class="label">
                                    <span class="handmade_label">handmade</span>
                                </p>
                                <p class="input">
                                    <span><%= @company.delivery_time %></span>
                                </p>
                                <div class="clear"></div>
                            </div>
                        <% end %>
                    </form>
                <% end %>
            </div>
            <div class="clear"></div>
            <%= render 'shared/right_col_footer_nav' %>
        </div>
    </div>
</div>
<div class="clear"></div>

<div id="buffer" style="display: none;"></div>
<%= content_for :js do %>
    <script type="text/html" id="product_tmpl">
        <div id="part_{{ hash }}" data-color-hash="{{ color_hash }}" {{#is_color}}class="color_part"{{/is_color}}>
            <% %w{product price qty}.each do |attr| %>
                <input type="hidden" name="<%= attr %>{{ count }}" class="part_<%= attr %>" value="{{ <%= attr %> }}">
            <% end %>
        </div>
    </script>
    <script type="text/html" id="prompt_tmpl">
        <div>
            <b>Including &ldquo;{{product}}&rdquo; adds a charge of ${{price}} to this bag.</b>
        </div>
        <ul>
            <li>You will only be charged for your most expensive fabric choice.</li>
            <li>The charge is only applied once per bag.</li>
            <li>Use it as many times as you&rsquo;d like!</li>
        </ul>
    </script>
    <script>
        $(document).ready(function() {
            $.productOrder()
        });
        $(window).load(function() {
            $('.content').equalHeights();
        });
    </script>
<% end %>
