<form method="post" action="<%= APP_CONFIG['store_url'] %>">
  <%# Mal-e integration %>
  <input type="hidden" name="userid" value="<%= APP_CONFIG['store_userid'] %>">
  <input type="hidden" name="product1[]" value="<%= @product.title %>">
  <input type="hidden" name="price1" value="<%= @product.price %>">
  <input type="hidden" name="qty1" value="1">
  <div id="addons"></div>

  <% unless @product.public? %>
    <p class="private" style="position: absolute; top: 0; left: 0; padding: 2px 6px; border: 1px solid rgba(0,0,0,.2);-webkit-box-shadow: 0 0 4px rgba(0,0,0,.3); border-top: 0;">
      private!
    </p>
  <% end %>
  <p id="notice">
    <%= notice %>
  </p>
  <h2>
    <%= @product.title %>
  </h2>
  <%= render :partial => 'shared/slideshow' %>
  <h3>
    About <%= @product.title %>
  </h3>
  <p>
    <%= @product.description %>
  </p>
  <p>
    $<%= @product.price %>
  </p>
  <h3>
    Specs
  </h3>
  <p>
    <%= @product.specs %>
  </p>
  <% if @product.parts.present? %>
    <h3>
      Parts
    </h3>
    <div class="fields">
      <% @product.parts.each do |part| %>
        <div class="field">
          <p>
            <%# If it has a price, display a checkbox so they can add it. %>
            <% if part.price.present? %>
              <input type="checkbox" data-count="<%= part.id %>" data-product="<%= part.title %>" data-price="<%= part.price %>" class="add_product">
            <% end %>
            <%= part.title %>
            <%= "$#{part.price}" if part.price.present? %>
          </p>
          <% unless part.colors.empty? %>
            <p>
              <select name="product1[]">
                <% part.colors.each do |color| %>
                  <option
                    class="<%= "has_price" unless color.price.nil? %>"
                    value="<%= part.title %> (<%= color.title %><%= " ($#{color.price})" unless color.price.nil? %>) ">
                    <%= color.title %>
                    <%= "($#{color.price})" unless color.price.nil? %>
                  </option>
                <% end %>
              </select>
              <%# select_tag "#{part.title}_colors", options_from_collection_for_select(part.colors, "id", "title") %>
            </p>
          <% end %>
        </div>
        <p>
          ------
        </p>
      <% end %>
    </div>
  <% end %>
  <p>
    <input type="submit">
    <%# link_to "Checkout", :action => "cart", :id => @product %>
  </p>
</form>
<%= content_for :js do %>
  <script type="text/html" id="product_tmpl">
    <div id="addon_{{ count }}">
      <input type="hidden" name="product{{ count }}" value="{{ product }}">
      <input type="hidden" name="price{{ count }}" value="{{ price }}">
      <input type="hidden" name="qty{{ count }}" value="{{ qty }}>">
    </div>
  </script>
  <script>
    $('.add_product').click(function() {
      if ($(this).attr("checked")) {
        var obj = {
          'count': $(this).data('count'),
          'product': $(this).data('product'),
          'price': $(this).data('price'),
          'qty': '1'
        }
        $('#addons').append(
          ich.product_tmpl(obj)
        )
      } else {
        var count = $(this).data('count');
        $('#addon_' + count).remove();
      }
    });
  </script>
<% end %>