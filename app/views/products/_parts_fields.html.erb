<%#
    HACK      HACK        HACK         HACK HACK   HACK   HACK     HACK
    HACK      HACK      HACK  HA      HACK         HACK  HACK      HACK
    HACK HACK HACK     HACK   HAC     HACK         HACKHACK        HACK
    HACK      HACK    HACKHACK HACK   HACK         HACK  HACK
    HACK      HACK   HACK      HACK    HACK HACK   HACK   HACK     HACK

     Set the correct name value on the color checkboxes so they match
                        the corresponding part.

    See here for someone solving something similar:
     http://chrisblunt.com/2009/10/12/rails-getting-the-id-of-form-fields-inside-a-fields_for-block/
%>
<%
  if f.object.id.nil?
    eye_dee = 'new_parts'
  else
    eye_dee = f.object.id
    obj_name = f.object_name # product[parts_attributes][0]
  end
%>

<div class="indent group">
  <div class="field">
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>
  <div class="field">
    <%= f.label :price %><br>
    <%= f.text_field :price %>
    <p class="hint">
        ex: 150.00
    </p>
  </div>
  <div class="field">
    <%= f.label :colors, "Available in the following colors", :class => "available_in_the_following_colors" %><br>
    <% Color.all.each do |color| %>
      <label>
        <%
          unless eye_dee == "new_parts"
            # Does this color.id match any of colors set
            needle = color
            match = Part.find_by_id(eye_dee).colors.any? do |haystack|
              haystack.id == needle.id
            end
          end
        %>
        <% if eye_dee == "new_parts" %>
          <%= check_box_tag "product[parts_attributes][#{eye_dee}][color_ids][]", color.id, match %>
        <% else %>
          <%= check_box_tag "#{obj_name}[color_ids][]", color.id, match %>
        <% end %>
        <%= color.title %>
        <% unless color.price.blank? %>
          $<%= color.price %>
        <% end %>
      </label>
      <br>
    <% end %>
  </div>
  <div class="field destroy">
    <label>
      <%= f.hidden_field :_destroy %>
      <%= link_to_function "Remove Part", "remove_fields(this)" %>
    </label>
  </div>
</div>