<h1>Products</h1>
<table>
  <tr>
    <th>Title</th>
    <th>Type</th>
    <th>Description</th>
    <th>Price</th>
    <th>Flickr tag</th>
    <th>Specs</th>
    <th>Status</th>
    <th></th>
    <th></th>
    <th></th>
  </tr>
<% @products.each do |product| %>
  <tr>
    <td><%= product.title %></td>
    <td><%= product.kind %></td>
    <td><%= product.description %></td>
    <td><%= product.price %></td>
    <td><%= product.flickr_tag %></td>
    <td><%= product.specs %></td>
    <td  class="<%= 'private' unless product.public? -%>"><%= product.status %></td>
    <td><%= link_to 'Show', product %></td>
    <td><%= link_to 'Edit', edit_product_path(product) %></td>
    <td><%= link_to 'Destroy', product, :confirm => 'Are you sure?', :method => :delete %></td>
  </tr>
<% end %>
</table>
<div class="fields">
  <label>
    <%= link_to 'New Product', new_product_path %>
  </label>
</div>
