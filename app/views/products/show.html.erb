<% unless @product.public? %>
  <p class="private" style="position: absolute; top: 0; left: 0; padding: 2px 6px; border: 1px solid rgba(0,0,0,.2);-webkit-box-shadow: 0 0 4px rgba(0,0,0,.3); border-top: 0;">
    private!
  </p>
<% end %>
<p id="notice">
  <%= notice %>
</p>

<h2>
  <%= @product.title %>
</h2>


<h3>
  About <%= @product.title %>
</h3>
<p>
  <%= @product.description %>
</p>

<p>
  $<%= @product.price %>
</p>

<h4>
  Specs
</h4>
<p>
  <%= @product.specs %>
</p>

<h4>
  Parts
</h4>
<ul>
  <% @product.parts.each do |part| %>
    <li>
      <%= link_to part.title, part -%>
      (<% part.colors.each do |color| %>
        <%= color.title -%>
      <% end -%>)
    </li>
  <% end %>
</ul>

<% unless @photos.nil? %>
  <ul id="fancybox_list">
    <% @photos.each_key do |photo| -%>
      <li class="fancybox_item">
        <a class="fancybox" rel="fancybox" href="<%= @photos[photo]['large'] -%>" title="<%= @photos[photo]['title'] %>***<%= @photos[photo]['flickr_url'] -%>">
          <img class="thumb" src="<%= @photos[photo]['medium'] %>">
        </a>
      </li>
    <% end -%>
  </ul>
<% else %>
  <p>
    Photos are not available.
  </p>
<% end %>