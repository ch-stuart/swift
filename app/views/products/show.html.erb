<% unless @product.public? %>
    <p id="private_notice">
        private!
    </p>
<% end %>
<div class="eleven columns col-main">
    <h2>
        <%= @product.title %>
    </h2>
    <%= render "shared/slideshow" %>
    <%= raw md @product.description %>
    <h3>
        Specifications
    </h3>
    <p>
        <%= raw md @product.specs %>
    </p>
</div>
<div class="five columns col-sidebar">
    <p>
        <% if @product.is_product? %>
            <%= link_to "Design your bags", order_product_path(@product), :id => "submit_order" %>
        <% else %>
            <%= link_to "Buy it", order_product_path(@product), :id => "submit_order" %>
        <% end %>
    </p>
    <p>
        <%= @product.humane_price %>
    </p>
    <%= render 'testimonials' %>
</div>
<br class="clear">
