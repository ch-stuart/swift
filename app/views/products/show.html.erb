<% unless @product.public? %>
  <p class="private" style="position: absolute; top: 0; left: 0; padding: 2px 6px; border: 1px solid rgba(0,0,0,.2);-webkit-box-shadow: 0 0 4px rgba(0,0,0,.3); border-top: 0;">
    private!
  </p>
<% end %>
<p id="notice">
  <%= notice %>
</p>

<h2>
  <%= @product.title %>
</h2>


<h3>
  About <%= @product.title %>
</h3>
<p>
  <%= @product.description %>
</p>

<p>
  $<%= @product.price %>
</p>

<h4>
  Specs
</h4>
<p>
  <%= @product.specs %>
</p>

<h4>
  Parts
</h4>
<ul>
  <% @product.parts.each do |part| %>
    <li>
      <%= link_to part.title, part -%>
      (<% part.colors.each do |color| %>
        <%= color.title -%>
      <% end -%>)
    </li>
  <% end %>
</ul>

<% unless @photos.nil? %>
  <div id="featured"> 
    <% @photos.each_key do |photo| -%>
      <img
        id="photo_<%= @photos[photo]['id'] -%>"
        src="<%= @photos[photo]['large'] -%>"
        data-text="<%= @photos[photo]['title'].empty? ? 'Untitled' : @photos[photo]['title'] %>"
        data-caption="#photo_caption_<%= @photos[photo]['id'] -%>"
        width="<%= @photos[photo]['large_width'] -%>"
        height="<%= @photos[photo]['large_height'] -%>">
      <span class="orbit-caption" id="photo_caption_<%= @photos[photo]['id'] -%>">
        <b>
          <%= @photos[photo]['title'].empty? ? 'Untitled' : @photos[photo]['title'] -%>
        </b>
        <%= @photos[photo]['description'] -%>
        <a href="<%= @photos[photo]['flickr_url'] -%>">
          View on Flickr
        </a>
      </span>
    <% end -%>
  </div>
<% else %>
  <p>
    Photos are not available.
  </p>
<% end %>




<%= content_for :js do %>
  <script>
    $(window).load(function() {
      $('#featured').orbit({
        bullets: true,
        bulletText: true,
        timer: false,
        directionalNav: false,
        captions: true
      });
    });
  </script>
<% end %>
