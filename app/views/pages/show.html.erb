<%= content_for :flash do %>
    <p id="notice">
        <%= notice %>
    </p>
<% end %>
<% unless @page.public? %>
    <p id="private_notice">
        private!
    </p>
<% end %>

<div class="grid_12 left_col">
    <div class="content_wrapper">
        <div class="content">
            <%= render :partial => 'shared/slideshow' %>
            <article>
                <h2>
                    <%= @page.title %>
                </h2>
                <%= raw md @page.body %>
            </article>
        </div>
    </div>
</div>
<div class="grid_12 right_col">
    <div class="content_wrapper">
        <div class="content">
            <% if @page.video_html.present? %>
                <%= raw @page.video_html %>
            <% end %>
            <%= link_to "Back to Bags", root_path, :id => "bike_btn" %>
            <div class="clear"></div>
            <%= image_tag "footer-logo.gif", :id => "logo", :style => "float: right" %>
            <div class="clear"></div>
        </div>
    </div>
</div>
<div class="clear"></div>

<%= content_for :js do %>
    <script>
        $(window).load(function() {
            $('.content').equalHeights()
        })
    </script>
<% end %>