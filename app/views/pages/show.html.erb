<% unless @page.public? %>
    <p id="private_notice">
        private!
    </p>
<% end %>

<div class="grid_12 left_col">
    <div class="content_wrapper">
        <div class="content">
            <%= render :partial => 'shared/slideshow' %>
            <div class="text_content">
                <article>
                    <h2>
                        <%= @page.title %>
                    </h2>
                    <%= raw md @page.body %>
                </article>
            </div>
        </div>
    </div>
</div>
<div class="grid_12 right_col">
    <div class="content_wrapper">
        <div class="content">
            <% if @page.video_html.present? %>
                <%= raw @page.video_html %>
            <% end %>
            <div class="clear"></div>
            <%= render :partial => 'shared/right_col_footer_nav' %>
        </div>
    </div>
</div>
<div class="clear"></div>

<%= content_for :js do %>
    <script>
        $(window).load(function() {
           $('.content').equalHeights()
        })
    </script>
<% end %>