<h1>
  <%= @subtitle %>
</h1>

<table>
  <tr>
    <th>Status</th>
    <th>Title</th>
    <th>Summary</th>
    <th>Body</th>
    <th>Path</th>
    <th>Featured?</th>
    <th></th>
  </tr>

<% @pages.each do |page| %>
  <tr>
    <td><%= image_tag "#{page.status}.png" %></td>
    <td>
      <%= link_to page.title, page %>
      <%= link_to image_tag("edit.png"), edit_page_path(page) %>
    </td>
    <td><%= truncate(page.summary, :length => 30) %></td>
    <td><%= truncate(page.body, :length => 30) %></td>
    <td><%= page.path %></td>
    <td class="<%= 'featured' unless page.featured? -%>"><%= page.featured %></td>
    <td><%= link_to image_tag("destroy.png"), page, :confirm => 'Are you sure?', :method => :delete %></td>
  </tr>
<% end %>
</table>

<p>
  <%= link_to 'New Page', new_page_path %>
</p>
